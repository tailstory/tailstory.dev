---
import { GIT_COMMIT_HASH, REPO_URL } from "@/constants";
---

<footer>
    <span>
        &copy; {new Date().getFullYear()} Tailstory LLC &middot;
        <a href={`${REPO_URL}/commit/${GIT_COMMIT_HASH}`}>
            {GIT_COMMIT_HASH.slice(0,7)}
        </a>
    </span>
</footer>

<style>
    footer {
        position: fixed;
        bottom: 0;
        left: 0;
        right: 0;
        text-align: center;
        font-size: 0.75rem;
        padding: 1rem;
        color: var(--color-text-muted, #94a3b8);
    }

    footer a {
        color: var(--color-text-muted, #94a3b8);
        text-decoration: underline;
        text-underline-offset: 2px;
    }

    footer a:hover {
        color: var(--color-primary-light, #8b83ff);
    }
</style>
